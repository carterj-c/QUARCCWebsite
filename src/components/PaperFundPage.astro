---
import SystemBox from "./SystemBox.astro";

const { portfolios = [] } = Astro.props;
---

<div class="paper-fund-shell">
  <SystemBox title="Paper Portfolios">
    <p class="paper-fund-intro">
      Research-led paper portfolios managed by QUARCC. Open a portfolio to view holdings, equity
      history, and live snapshots when available.
    </p>

    <div class="paper-fund-grid">
      {portfolios.map((portfolio) => (
        <a class="paper-fund-card" href={`/paper-fund/${portfolio.slug}`}>
          <div class="paper-fund-card-top">
            <div>
              <h2 class="paper-fund-card-title">{portfolio.name}</h2>
              <p class="paper-fund-card-strategy">{portfolio.strategy}</p>
            </div>
            <span class:list={["paper-fund-card-status", portfolio.status !== "Active" && "inactive"]}>
              {portfolio.status}
            </span>
          </div>

          <p class="paper-fund-card-summary">{portfolio.summary}</p>
          <span class="paper-fund-card-link">Open portfolio →</span>
        </a>
      ))}
    </div>
  </SystemBox>
</div>

<style>
  .paper-fund-shell {
    max-width: 1100px;
    margin: 0 auto;
  }

  .paper-fund-intro {
    margin-bottom: 1.1rem;
    color: var(--color-text-muted);
    max-width: 48rem;
  }

  .paper-fund-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .paper-fund-card {
    display: grid;
    gap: 0.8rem;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.4rem;
    background: linear-gradient(180deg, rgba(8, 9, 12, 0.98), rgba(11, 12, 15, 0.98));
    color: inherit;
  }

  .paper-fund-card:hover {
    text-decoration: none;
    border-color: rgba(184, 255, 204, 0.16);
    background: linear-gradient(180deg, rgba(10, 11, 14, 0.99), rgba(13, 14, 18, 0.99));
  }

  .paper-fund-card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .paper-fund-card-title {
    font-size: 1.05rem;
    line-height: 1.15;
  }

  .paper-fund-card-strategy {
    margin-top: 0.3rem;
    font-size: 0.78rem;
    color: var(--color-primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .paper-fund-card-status {
    padding: 0.22rem 0.48rem;
    border: 1px solid var(--color-success);
    border-radius: 999px;
    color: var(--color-success);
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .paper-fund-card-status.inactive {
    border-color: var(--color-danger);
    color: var(--color-danger);
  }

  .paper-fund-card-summary {
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .paper-fund-card-link {
    color: var(--color-accent-2);
    font-size: 0.9rem;
  }
</style>
