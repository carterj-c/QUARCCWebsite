---
import SystemBox from "./SystemBox.astro";
import PaperFundClient from "./PaperFundClient.jsx";

const { portfolio } = Astro.props;
---

<div class="paper-fund-detail-shell">
  <SystemBox title={portfolio.name}>
    <a href="/paper-fund" class="paper-fund-back">← All portfolios</a>

    <div class="paper-fund-detail-head">
      <div>
        <p class="paper-fund-detail-strategy">{portfolio.strategy}</p>
        <p class="paper-fund-detail-summary">{portfolio.summary}</p>
      </div>
      <span class:list={["paper-fund-detail-status", portfolio.status !== "Active" && "inactive"]}>
        {portfolio.status}
      </span>
    </div>

    <PaperFundClient client:load portfolios={[portfolio]} showDashboardHeader={false} />
  </SystemBox>
</div>

<style>
  .paper-fund-detail-shell {
    max-width: 1100px;
    margin: 0 auto;
  }

  .paper-fund-back {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .paper-fund-detail-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .paper-fund-detail-strategy {
    font-size: 0.82rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .paper-fund-detail-summary {
    margin-top: 0.45rem;
    color: var(--color-text-muted);
    max-width: 44rem;
    line-height: 1.5;
  }

  .paper-fund-detail-status {
    padding: 0.28rem 0.56rem;
    border: 1px solid var(--color-success);
    border-radius: 999px;
    color: var(--color-success);
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .paper-fund-detail-status.inactive {
    border-color: var(--color-danger);
    color: var(--color-danger);
  }

  @media (max-width: 640px) {
    .paper-fund-detail-head {
      flex-direction: column;
    }
  }
</style>
