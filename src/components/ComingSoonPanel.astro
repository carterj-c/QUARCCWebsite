---
interface Props {
  title: string;
  description: string;
  note?: string;
}

const { title, description, note = "" } = Astro.props;
---

<div class="coming-soon-shell">
  <div class="coming-soon-panel">
    <p class="coming-soon-kicker">Coming Soon</p>
    <h1 class="coming-soon-title">{title}</h1>
    <p class="coming-soon-description">{description}</p>
    {note ? <p class="coming-soon-note">{note}</p> : null}
  </div>
</div>

<style>
  .coming-soon-shell {
    max-width: 760px;
    margin: 0 auto;
  }

  .coming-soon-panel {
    border: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(8, 9, 12, 0.98), rgba(10, 11, 14, 0.98));
    padding: 1.5rem 1.6rem;
  }

  .coming-soon-kicker {
    color: var(--color-primary);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .coming-soon-title {
    margin-top: 0.45rem;
    font-size: 1.7rem;
    line-height: 1.15;
  }

  .coming-soon-description {
    margin-top: 0.75rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .coming-soon-note {
    margin-top: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
</style>
