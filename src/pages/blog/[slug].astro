---
import { Image } from "astro:assets";
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getBlogPosts, toContentSlug } from "../../lib/content";
import "../../styles/blog.css";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { slug: toContentSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const relatedPosts = (await getBlogPosts()).filter((entry) => entry.id !== post.id).slice(0, 3);
---

<BaseLayout
  title={`${post.data.title} - QUARCC`}
  description={post.data.description}
  pageClass="blog-shell"
>
  <article class="blog-post">
    <a href="/blog" class="blog-back">← Posts</a>

    {post.data.heroImage ? (
      <div class="blog-hero-image">
        <Image
          src={post.data.heroImage}
          alt={post.data.heroImageAlt || post.data.title}
          widths={[1200]}
          sizes="(max-width: 820px) 100vw, 48rem"
        />
      </div>
    ) : null}

    <h1 class="blog-post-title">{post.data.title}</h1>
    <div class="blog-post-meta">
      <span>{formatDate(post.data.pubDate)}</span>
      {post.data.updatedDate ? (
        <span class="blog-post-updated">Updated {formatDate(post.data.updatedDate)}</span>
      ) : null}
    </div>

    {post.data.tags.length ? (
      <div class="blog-post-tags">
        {post.data.tags.map((tag) => (
          <span class="blog-post-tag">{tag}</span>
        ))}
      </div>
    ) : null}

    <p class="blog-post-lead">{post.data.description}</p>

    <div class="blog-prose">
      <Content />
    </div>

    <section class="blog-more">
      <h2 class="blog-sidebar-title">More From The Archive</h2>
      <ul class="blog-more-list" role="list">
        {relatedPosts.map((entry) => (
          <li class="blog-post-row">
            <div class="blog-date">{formatDate(entry.data.pubDate)}</div>
            <a class="blog-preview-title" href={`/blog/${toContentSlug(entry.id)}`}>
              {entry.data.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </article>
</BaseLayout>
