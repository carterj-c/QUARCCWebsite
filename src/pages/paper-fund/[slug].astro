---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PaperFundDetailPage from "../../components/PaperFundDetailPage.astro";
import { getPortfolios, toContentSlug } from "../../lib/content";

export async function getStaticPaths() {
  const portfolios = await getPortfolios();

  return portfolios.map((entry) => ({
    params: { slug: toContentSlug(entry.id) },
    props: {
      portfolio: {
        id: toContentSlug(entry.id),
        slug: toContentSlug(entry.id),
        ...entry.data,
      },
    },
  }));
}

const { portfolio } = Astro.props;
---

<BaseLayout
  title={`${portfolio.name} - Paper Fund - QUARCC`}
  description={portfolio.summary}
>
  <PaperFundDetailPage portfolio={portfolio} />
</BaseLayout>
