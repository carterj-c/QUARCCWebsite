---
import "../index.css";
import "../components/Layout.css";
import CliInput from "../components/CliInput.jsx";

const { title, description, showHomeLink = true, pageClass = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="layout-container">
      {showHomeLink ? (
        <a href="/" class="home-link">
          &lt; Home
        </a>
      ) : null}
      <main class:list={["layout-content", pageClass]}>
        <slot />
      </main>
      <footer class="layout-footer">
        <CliInput client:load />
      </footer>
    </div>
  </body>
</html>
